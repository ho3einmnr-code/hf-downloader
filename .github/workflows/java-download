name: Download JDK 17 (Windows x64)

on:
  workflow_dispatch:

jobs:
  download-jdk:
    runs-on: windows-latest

    steps:
      - name: Download JDK 17 zip
        run: |
          mkdir C:\jdk
          curl -L ^
            https://github.com/adoptium/temurin17-binaries/releases/latest/download/OpenJDK17U-jdk_x64_windows_hotspot.zip ^
            -o C:\jdk\jdk17.zip

      - name: Upload JDK 17 as artifact
        uses: actions/upload-artifact@v4
        with:
          name: jdk-17-windows-x64
          path: C:\jdk\jdk17.zip
